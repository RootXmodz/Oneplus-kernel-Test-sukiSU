# ================================================================
#  Nord 4 (aether / sm7675) — Kernel Config Fragment
#  Android 16 | GKI 6.1 | aarch64
#  Use karo: Wild Kernels fork mein configs/nord4.config
# ================================================================

# ── Device Identity ────────────────────────────────────────────
CONFIG_LOCALVERSION="-Wild-SukiSU-Nord4"

# ── SukiSU Ultra + KSU Core ───────────────────────────────────
CONFIG_KSU=y
CONFIG_KSU_WITH_KPROBES=y
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_KRETPROBES=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# ── KPM (Kernel Patch Module) ─────────────────────────────────
CONFIG_KSU_KPM=y

# ── SUSfs v2 Full Suite ───────────────────────────────────────
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_OVERLAYFS=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_HAS_MAGIC_MOUNT=y

# ── BBG — Baseband Guard LSM (Wild exclusive) ─────────────────
CONFIG_SECURITY_BBG=y

# ── Unicode Bypass Fix (Wild exclusive) ───────────────────────
CONFIG_UNICODE=y

# ── ZRAM + Compression Algorithms ────────────────────────────
CONFIG_ZRAM=y
CONFIG_ZSMALLOC=y
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZ4HC=y
CONFIG_CRYPTO_LZ4K=y
CONFIG_CRYPTO_LZ4KD=y
CONFIG_CRYPTO_ZSTD=y
# ZRAM default algo
CONFIG_ZRAM_DEF_COMP_LZ4KD=y

# ── TCP Congestion Control ────────────────────────────────────
CONFIG_TCP_CONG_ADVANCED=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_TCP_CONG_WESTWOOD=y
CONFIG_TCP_CONG_HTCP=y

# ── Network / Netfilter ───────────────────────────────────────
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_IP_NF_TARGET_TTL=y           # TTL masking (gaming anti-detect)
CONFIG_NETFILTER_XT_TARGET_MARK=y
CONFIG_IP_SET=y                     # Wild: IP_SET support
CONFIG_IP6_NF_NAT=y                 # Wild: IPv6 NAT fix
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y

# ── WireGuard VPN ─────────────────────────────────────────────
CONFIG_WIREGUARD=y

# ── Maphide (LineageOS / jit-zygote detection bypass) ─────────
CONFIG_KSU_SUSFS_SUS_MOUNT=y        # already set above, covers maphide

# ── tmpfs XATTR — Mountify Support ───────────────────────────
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y

# ── F2FS Filesystem ───────────────────────────────────────────
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_COMPRESSION=y
CONFIG_F2FS_FS_LZ4=y
CONFIG_F2FS_FS_ZSTD=y
CONFIG_F2FS_FS_LZORLE=y

# ── Scheduler / CPU Performance ──────────────────────────────
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_HZ_300=y
# CONFIG_HZ_250 is not set

# ── LTO Optimization ─────────────────────────────────────────
# CONFIG_LTO_NONE is not set
CONFIG_LTO_CLANG_THIN=y

# ── Ptrace Fix (kernel < 5.16) ────────────────────────────────
CONFIG_HAVE_ARCH_TRACEHOOK=y

# ── Debug (disable for release builds) ───────────────────────
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_KASAN is not set
